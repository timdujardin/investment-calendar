{
  "name": "investment-calendar",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run pwa:icons && tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "pwa:icons": "node scripts/generate-pwa-icons.mjs",
    "check:precommit": "npm run format:code && npm run check:all",
    "check:all": "npm run check:lint && npm run check:types",
    "check:lint": "eslint --fix --report-unused-disable-directives .",
    "check:types": "tsc --noEmit --extendedDiagnostics",
    "format:code": "prettier --write ."
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-is": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "recharts": "^3.8.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-depend": "^1.5.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-react-you-might-not-need-an-effect": "^0.9.2",
    "eslint-plugin-sonarjs": "^4.0.2",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "sharp": "^0.34.5",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^8.0.0",
    "vite-plugin-pwa": "^1.2.0",
    "xlsx": "^0.18.5"
  }
}
